{
    "compilerOptions": {
        "target": "esnext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ESNext"],
        "types": ["node", "electron"],
        "allowJs": true,
        "checkJs": false,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "@shared/*": ["../shared/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.json"],
    "exclude": ["../../node_modules", "../../out", "../../dist"]
}
