{
    "name": "repair2",
    "version": "2.5.1-next.0",
    "description": "REPAIR v2",
    "main": "./out/main/index.js",
    "type": "module",
    "author": "beyondspace.com",
    "homepage": "https://beyond-space.kr",
    "scripts": {
        "format": "prettier --plugin prettier-plugin-svelte --write .",
        "start": "electron-vite preview",
        "dev:editor": "vite --config editor.vite.config.mjs --force",
        "dev:play": "vite --config play.vite.config.mjs --force",
        "dev": "npx concurrently --kill-others \"electron-vite dev --inspect=9229\" \"npm run dev:play\" \"npm run dev:editor\"",
        "build:main": "electron-vite build",
        "build:editor": "vite build --config editor.vite.config.mjs",
        "build:play": "vite build --config play.vite.config.mjs",
        "build:splash": "xcopy src\\renderer\\splash out\\splash /E /I /Y",
        "build": "npm-run-all --parallel build:main build:editor build:play build:splash",
        "postinstall": "electron-builder install-app-deps",
        "build:unpack": "npm run build && electron-builder --dir --config electron-builder.config.js",
        "build:win": "npm run build && electron-builder --win --config electron-builder.config.js"
    },
    "dependencies": {
        "@fainthit/uiohook-napi-suppress": "^1.6.4",
        "msgpackr": "^1.11.10",
        "serialport": "^13.0.0",
        "svelte": "^5.20.1",
        "vite": "^7.0.0"
    },
    "devDependencies": {
        "@babel/core": "^7.26.10",
        "@babel/generator": "^7.26.10",
        "@babel/parser": "^7.26.10",
        "@babel/traverse": "^7.26.10",
        "@electron-toolkit/utils": "^4.0.0",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "archiver": "^7.0.1",
        "bonjour-service": "^1.3.0",
        "chokidar": "^5.0.0",
        "concurrently": "^9.1.2",
        "easing-utils": "^1.0.0",
        "electron": "^34.2.0",
        "electron-builder": "^25.1.8",
        "electron-prompt": "^1.7.0",
        "electron-store": "^11.0.2",
        "electron-vite": "^5.0.0",
        "fs-extra": "^11.3.0",
        "hangul-js": "^0.2.6",
        "node-stream-zip": "^1.15.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.5.1",
        "prettier-plugin-svelte": "^3.3.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "semver": "^7.7.4",
        "socket.io-client": "^4.8.1",
        "twgl.js": "^7.0.0",
        "vite-plugin-electron-renderer": "^0.14.6"
    }
}
